---
import Layout from '../../layouts/Layout.astro';
import properties from '../../data/properties.json';

export async function getStaticPaths() {
  return properties.map((property) => ({
    params: { id: property.id },
    props: { property },
  }));
}

const { property } = Astro.props;
const isAlquiler = property.type.toLowerCase() === 'alquiler';
---

<Layout 
  title={`${property.type}: ${property.title} | GHI Housing`}
  description={`Detalles de la propiedad en ${property.location}. Área: ${property.area}, Habitaciones: ${property.rooms}, Baños: ${property.bathrooms}. Contacta con nuestro asesor.`}
  keywords={`${property.type.toLowerCase()} propiedad, GHI Housing, inmuebles Perú, ${property.location}`}
  whatsappText={property.whatsappMessage}
  ogImage={property.cardImage}
  ogType="article"
>
  <main class="main" style="margin-top: 80px;">
    <section id="property-detail" class="property-detail section">
      <div class="container">
        
        <!-- Breadcrumb Navigation -->
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicio</a></li>
            <li class="breadcrumb-item"><a href="/inmobiliaria">Inmobiliaria</a></li>
            <li class="breadcrumb-item active" aria-current="page">{property.title}</li>
          </ol>
        </nav>

        <div class="row">
          <div class="col-lg-8">
            <div class="property-header">
              <h1 class="fw-bold" style="color: #344761;">{property.title}</h1>
              <p class={`property-price ${isAlquiler ? 'price-alquiler' : 'price-venta'}`}>
                {property.price}
              </p>
              <p class="text-muted"><i class="bi bi-geo-alt-fill"></i> {property.location}</p>
              {property.maintenance && (
                <span class="badge bg-secondary mb-2">{property.maintenance}</span>
              )}
            </div>

            <!-- Image Slider using Swiper -->
            <div class="swiper propertySwiper mt-4 mb-4">
              <div class="swiper-wrapper">
                {property.images.map((imgUrl, index) => (
                  <div class="swiper-slide">
                    <img src={imgUrl} alt={`${property.title} - Vista ${index + 1}`} class="img-fluid" />
                  </div>
                ))}
              </div>
              <div class="swiper-pagination"></div>
            </div>

            <!-- Key Features -->
            <h2 class="h4 fw-bold mb-3 mt-5">Características Principales</h2>
            <div class="row property-details mb-5">
              <div class="col-md-4 col-sm-6">
                <div class="detail-card">
                  <p class="mb-0"><i class="bi bi-house-door icon-feature"></i> Tipo: {property.type}</p>
                </div>
              </div>
              <div class="col-md-4 col-sm-6">
                <div class="detail-card">
                  <p class="mb-0"><i class="bi bi-rulers icon-feature"></i> Área Total: {property.area}</p>
                </div>
              </div>
              {property.areaCovered && (
                <div class="col-md-4 col-sm-6">
                  <div class="detail-card">
                    <p class="mb-0"><i class="bi bi-rulers icon-feature"></i> Área Cubierta: {property.areaCovered}</p>
                  </div>
                </div>
              )}
              <div class="col-md-4 col-sm-6">
                <div class="detail-card">
                  <p class="mb-0">
                    <i class="bi bi-door-open icon-feature"></i> 
                    {property.rooms === 1 ? 'Dormitorio: 1' : `Habitaciones: ${property.rooms}`}
                  </p>
                </div>
              </div>
              <div class="col-md-4 col-sm-6">
                <div class="detail-card">
                  <p class="mb-0">
                    <i class="bi bi-droplet icon-feature"></i> 
                    {property.bathrooms === 1 ? 'Baño: 1' : `Baños: ${property.bathrooms}`}
                  </p>
                </div>
              </div>
              <div class="col-md-4 col-sm-6">
                <div class="detail-card">
                  <p class="mb-0"><i class="bi bi-calendar-check icon-feature"></i> Antigüedad: {property.age}</p>
                </div>
              </div>
            </div>

            <!-- Description -->
            <h2 class="h4 fw-bold mb-3">Descripción Completa</h2>
            <p style="white-space: pre-line; line-height: 1.6; color: #4b5563;">
              {property.description}
            </p>

            {property.distribution && (
              <>
                <h3 class="h5 fw-bold mt-4 mb-3">Distribución del Inmueble</h3>
                <p style="line-height: 1.6; color: #4b5563;">{property.distribution}</p>
              </>
            )}

            {property.rules && (
              <>
                <h3 class="h5 fw-bold mt-4 mb-3">Normas y Convivencia</h3>
                <div class="p-3 bg-light rounded border mb-4">
                  <p class="mb-0 small text-muted"><i class="bi bi-info-circle-fill text-primary me-2"></i> {property.rules}</p>
                </div>
              </>
            )}

            {property.nearPoints && property.nearPoints.length > 0 && (
              <>
                <h3 class="h5 fw-bold mt-4 mb-3">Lugares Cercanos y Accesos</h3>
                <div class="row mb-4">
                  {property.nearPoints.map((point) => (
                    <div class="col-md-6 mb-2">
                      <div class="d-flex align-items-start">
                        <i class="bi bi-geo-fill text-danger me-2 mt-1"></i>
                        <span class="small text-muted">{point}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </>
            )}
            
            <!-- Amenities -->
            {property.amenities && property.amenities.length > 0 && (
              <>
                <h3 class="h5 fw-bold mt-5 mb-3">Amenidades y Detalles</h3>
                <ul class="list-group list-group-flush mb-5">
                  {property.amenities.map((amenity) => (
                    <li class="list-group-item"><i class="bi bi-check2-circle me-2 text-primary"></i> {amenity}</li>
                  ))}
                </ul>
              </>
            )}

            <!-- Extra Notes -->
            {property.extraNotes && (
              <div class="alert alert-info mt-4 mb-5" role="alert">
                <h4 class="alert-heading fw-bold h6"><i class="bi bi-info-circle-fill me-2"></i>Nota:</h4>
                <p class="mb-0 small">{property.extraNotes}</p>
              </div>
            )}

            <!-- Location Map -->
            {property.mapEmbedUrl && (
              <>
                <h3 class="h5 fw-bold mt-4 mb-3">Ubicación</h3>
                {property.addressDetails && (
                  <p class="text-muted small mb-3"><i class="bi bi-geo-alt"></i> {property.addressDetails}</p>
                )}
                <div class="ratio ratio-16x9 mb-5 shadow-sm rounded overflow-hidden">
                  <iframe 
                    src={property.mapEmbedUrl} 
                    width="100%" 
                    height="100%" 
                    style="border:0;" 
                    allowfullscreen="" 
                    loading="lazy" 
                    referrerpolicy="no-referrer-when-downgrade">
                  </iframe>
                </div>
              </>
            )}
          </div>

          <!-- Sidebar Form -->
          <div class="col-lg-4">
            <div class="sidebar p-4 border rounded shadow-sm sticky-top" style="top: 100px; background-color: #ffffff;">
              <h4 class="mb-4 text-center fw-bold">Agenda tu Visita</h4>
              <p class="text-center text-muted small mb-4">Contacta a nuestro asesor para más información o para coordinar una visita al inmueble.</p>

              <form action="https://formsubmit.co/contacto@ghi-housing.com" method="post" class="php-email-form contact-form">
                <input type="hidden" name="Asunto" value={`Consulta por propiedad: ${property.title}`}>
                <input type="hidden" name="Propiedad" value={`${property.title} (${property.price})`}>
                
                <div class="row">
                  <div class="col-12">
                    <div class="form-field">
                      <input type="text" name="name" class="form-input" id="userNameSide" placeholder=" " required>
                      <label for="userNameSide" class="field-label">Nombres</label>
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="form-field">
                      <input type="tel" class="form-input" name="phone" id="userPhoneSide" placeholder=" " required>
                      <label for="userPhoneSide" class="field-label">Teléfono</label>
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="form-field">
                      <input type="email" class="form-input" name="email" id="userEmailSide" placeholder=" " required>
                      <label for="userEmailSide" class="field-label">Correo</label>
                    </div>
                  </div>
                </div>

                <div class="form-field message-field">
                  <textarea class="form-input message-input" name="message" id="userMessageSide" rows="3" placeholder=" " required></textarea>
                  <label for="userMessageSide" class="field-label">Consulta</label>
                </div>

                <div class="my-3">
                  <div class="loading">Enviando...</div>
                  <div class="error-message"></div>
                  <div class="sent-message">¡Gracias! Tu solicitud ha sido enviada. Te contactaremos pronto.</div>
                </div>

                <button type="submit" class="btn btn-primary w-100 mt-2">
                  Enviar Solicitud
                  <span class="button-arrow">→</span>
                </button>
                <input type="hidden" name="_captcha" value="false">
                <input type="hidden" name="_next" value="https://www.ghi-housing.com/thanks">
                <input type="hidden" name="_template" value="table">
              </form>
              
              <hr class="my-4">
              <div class="text-center">
                <p class="mb-2 fw-bold small">¿Tienes dudas rápidas?</p>
                <a href={`https://wa.me/51934929777?text=${encodeURIComponent(property.whatsappMessage)}`} target="_blank" rel="noopener noreferrer" class="btn btn-success btn-sm w-100 py-2">
                  <i class="bi bi-whatsapp me-2"></i> Chatear por WhatsApp
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  #header.fixed-top {
    background-color: #344761;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
  }
  @media (min-width: 1200px) {
    #header.fixed-top .navmenu a {
      color: #fff !important;
    }
    #header.fixed-top .logo .sitename { 
      color: #fff !important; 
    }
  }
  @media (max-width: 1199px) {
    .navmenu a,
    .navmenu ul li { 
      color: var(--default-color) !important;
    }
    .navmenu .featured-link,
    .navmenu a:hover,
    .navmenu .active,
    .navmenu .active:focus {
      color: var(--nav-hover-color) !important; 
    }
    .navmenu .featured-link {
      color: #ff9900 !important;
    }
  }
</style>

<style>
  .property-header {
    padding: 20px 0;
    border-bottom: 1px solid #eee;
  }
  .property-price {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .price-alquiler {
    color: #007bff; /* Azul para alquiler */
  }
  .price-venta {
    color: #28a745; /* Verde para venta */
  }
  .property-details .icon-feature {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-right: 8px;
  }
  .detail-card {
    border-left: 4px solid var(--color-primary);
    padding: 15px;
    margin-bottom: 20px;
    background-color: #f8f9fa;
    border-radius: 0 4px 4px 0;
  }
  .swiper-slide img {
    height: 500px;
    width: 100%;
    object-fit: cover;
    border-radius: 8px;
  }
  
  /* Form Floating Label Styles */
  .form-field {
    position: relative;
    margin-bottom: 15px;
    height: 48px; 
  }
  .form-input {
    width: 100%;
    height: 100%; 
    padding: 15px 10px 0; 
    border: 1px solid #ccc;
    background-color: transparent;
    transition: border-color 0.3s;
    border-radius: 4px;
  }
  .form-input:focus {
    border-color: var(--color-primary);
    outline: none;
  }
  /* Estilo inicial de la etiqueta */
  .field-label {
    position: absolute;
    top: 0;
    left: 0;
    padding: 12px 10px;
    pointer-events: none;
    transition: 0.3s;
    color: #999;
    font-size: 1em; 
    transform-origin: left top;
  }
  /* Mover y escalar la etiqueta cuando el campo está lleno o enfocado */
  .form-input:focus + .field-label,
  .form-input:not(:placeholder-shown) + .field-label {
    transform: translateY(-8px) scale(0.85); 
    padding-top: 5px;
    color: var(--color-primary); 
  }
  .message-field {
    height: auto; 
    margin-bottom: 20px;
  }
  .message-field .form-input {
    height: auto;
    min-height: 100px; 
    padding-top: 20px;
  }
  /* Asegurar que el botón Chatear por WhatsApp tenga el color correcto */
  .btn-success {
    background-color: #25D366 !important;
    border-color: #25D366 !important;
    color: white;
    font-weight: 600;
  }
  .btn-success:hover {
    background-color: #20ba56 !important;
    border-color: #20ba56 !important;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper(".propertySwiper", {
      loop: true,
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
      autoplay: {
        delay: 5000,
        disableOnInteraction: false
      }
    });
  });
</script>
